{
  "compilerOptions": {
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* O Segredo do Monorepo: Atalhos diretos! */
    "paths": {
      "ui-shared/*": ["../../packages/ui-shared/*"],
      "shared-utils/*": ["../../packages/utils/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  /* Agora os caminhos estão corretos partindo da pasta app/admin/ */
  "include": ["src", "../../packages/ui-shared", "../../packages/utils"]
}